{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch posts template",
      "type": "shell",
      "command": "cmd",
      "args": ["/c", "npm", "run", "watch:posts"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "never",
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}
