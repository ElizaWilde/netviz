---
import Layout from '~/layouts/PageLayout.astro';
import { fetchPosts } from '~/utils/blog';
import { getPermalink } from '~/utils/permalinks';
import { BLOG_BLOCKS } from '~/config/blog-blocks';

const posts = await fetchPosts();

const blocks = (BLOG_BLOCKS || []).map((block) => {
  const count = posts.filter((post) => post.category?.title === block.title).length;
  return { ...block, count };
});

const metadata = {
  title: 'Blocks',
  description: 'The core learning blocks used to organize the blog.',
};
---

<Layout metadata={metadata}>
  <main class="mx-auto max-w-6xl px-4 py-12 sm:py-16">
    <div class="max-w-3xl">
      <div class="text-xs font-medium uppercase tracking-[0.18em] opacity-60">Categories</div>
      <h1 class="mt-3 text-3xl font-bold sm:text-4xl">Blog taxonomy</h1>
      <p class="mt-3 text-sm opacity-80 sm:text-base">
        Browse notes by the core knowledge block they belong to.
      </p>
    </div>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
      {
        blocks.map((block, index) => (
          <a
            href={getPermalink(block.slug, 'category')}
            class="rounded-2xl border border-white/30 bg-white/40 p-5 shadow-sm backdrop-blur-xl transition hover:bg-white/60 dark:border-white/10 dark:bg-slate-900/40 dark:hover:bg-slate-900/60"
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <div class="text-xs font-medium uppercase tracking-[0.18em] opacity-60">Block {index + 1}</div>
                <div class="mt-2 text-xl font-semibold">{block.title}</div>
              </div>
              <div class="rounded-full border border-white/30 px-3 py-1 text-sm dark:border-white/10">
                {block.count} posts
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </main>
</Layout>
